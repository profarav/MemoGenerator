NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
APOLLO_API_KEY=

# Optional: overrides the default "what we offer" description used to angle
# the memo's Questions and Talking Points. See lib/config/offering.ts.
OFFERING_DESCRIPTION=

# --- Google Docs export (see lib/google/docs.ts for setup steps) ---
# Service account JSON key, as raw JSON or base64. Needs the Docs + Drive APIs.
GOOGLE_SERVICE_ACCOUNT_KEY=
# Drive folder the memos land in. Share it with the service account as Editor.
GOOGLE_DRIVE_FOLDER_ID=
# Optional: give everyone at this domain edit access to each memo doc.
GOOGLE_DOC_SHARE_DOMAIN=

# --- ClickUp (posts the memo doc link as a comment on the deal) ---
CLICKUP_API_TOKEN=
# Only needed if you pass custom task ids (e.g. "DEV-1234") to the webhook.
CLICKUP_TEAM_ID=

# --- Booking webhook (Zapier) ---
# Shared secret the Zap sends as the X-Webhook-Secret header. Generate a long
# random string; requests without it are rejected.
BOOKING_WEBHOOK_SECRET=
# Public URL of this app, used to build memo links returned to the Zap.
NEXT_PUBLIC_APP_URL=
